# Пример для Ubuntu: /etc/nginx/sites-available/snaplot
# Замените server_name и путь к ssl после certbot.

upstream snaplot_uvicorn {
    server 127.0.0.1:8000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name ваш-домен.ru www.ваш-домен.ru;

    # После certbot сюда добавятся listen 443 ssl и пути к сертификатам.

    client_max_body_size 8m;

    location / {
        proxy_pass http://snaplot_uvicorn;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }
}
